# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Test / coverage / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Generated data artifacts (scans, indices, large arrays)
*.db
*.db-wal
*.db-shm
*.npz
*.lance/
*.html

# NOTE: tokographer/data/constrained_vocabs/*.npy is intentionally tracked
# (small token-ID vocabularies needed at runtime). Ignore other stray .npy.
*.npy
!tokographer/data/constrained_vocabs/*.npy
